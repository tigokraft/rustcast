[Unit]
Description=VibeCast System Bridge Daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/system-bridge
Restart=on-failure
RestartSec=5

# Privileged daemon for managing network, bluetooth, and system updates
User=root
Group=root

# Hardening options (can be adjusted later if they break zbus/Arch Toolkit)
NoNewPrivileges=false
ProtectSystem=full

[Install]
WantedBy=multi-user.target
